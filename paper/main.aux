\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Simulation results across chain lengths 2--6. Baseline cascade failure rate increases with chain depth, while circuit breaker mechanisms substantially reduce propagation. Adaptive control achieves the lowest CFR in longer chains.}}{4}{figure.1}\protected@file@percent }
