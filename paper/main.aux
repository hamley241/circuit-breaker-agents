\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Simulation results across chain lengths 2--6. Baseline cascade failure rate increases with chain depth, indicating compounding error propagation. Circuit breaker mechanisms substantially reduce cascade failures, with adaptive strategies achieving the lowest propagation rates in longer chains.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:simulation}{{1}{4}{Simulation results across chain lengths 2--6. Baseline cascade failure rate increases with chain depth, indicating compounding error propagation. Circuit breaker mechanisms substantially reduce cascade failures, with adaptive strategies achieving the lowest propagation rates in longer chains}{figure.1}{}}
