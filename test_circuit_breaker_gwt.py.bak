#!/usr/bin/env python3
"""
Given-When-Then Tests for Circuit Breaker Experiment
====================================================
Tests ALL chain lengths (2-6) with proper baseline vs circuit breaker behavior.

ISSUE DESCRIPTION:
- Chain 2: 5,547 CB trips but only 1% reduction (should be ~80%)
- Chain 6: 0 CB trips but 39% "reduction" (impossible)

ROOT CAUSES TO TEST:
1. Circuit breakers tripping too early (not allowing cascades to form)  
2. CFR calculation issues when CB blocks everything
3. Different behavior across chain lengths
"""
import unittest
import sys
import os
sys.path.append(os.path.dirname(__file__))

from circuit_breaker_experiment_fixed import ConfigurableChainSystem, CONDITIONS
from circuit_breaker import Response, CircuitBreakerOpenError
import json
import random


class CircuitBreakerGWTTests(unittest.TestCase):
    """Given-When-Then style tests for circuit breaker experiment."""
    
    def setUp(self):
        """Set up test fixtures."""
        self.seed = 42
        self.test_runs = 20  # Smaller runs for faster testing
        
    def create_chain_system(self, chain_length: int, condition: str, run_id: str) -> ConfigurableChainSystem:
        """Create a chain system with the specified chain length."""
        return ConfigurableChainSystem(condition, run_id, chain_length, seed=self.seed)
        
    def run_multiple_trials(self, chain_length: int, condition: str, runs: int = None) -> dict:
        """Run multiple trials and return aggregated results."""
        if runs is None:
            runs = self.test_runs
            
        results = []
        for i in range(runs):
            system = self.create_chain_system(chain_length, condition, f"{condition}_{i:03d}")
            result = system.run_chain()
            results.append(result)
        
        # Aggregate metrics
        cfr_values = [r["cfr"]["cfr_rate"] for r in results]
        completion_values = [1 if r["task_completed"] else 0 for r in results]
        trip_values = [r["metrics"]["circuit_trips"] for r in results]
        
        return {
            "avg_cfr": sum(cfr_values) / len(cfr_values) if cfr_values else 0,
            "completion_rate": sum(completion_values) / len(completion_values) if completion_values else 0,
            "avg_trips": sum(trip_values) / len(trip_values) if trip_values else 0,
            "total_trips": sum(trip_values),
            "results": results,
            "chain_length": chain_length,
            "condition": condition,
            "runs": runs
        }

    # ========================================
    # CHAIN 2 TESTS  
    # ========================================
    
    def test_2a_chain_2_baseline(self):
        """
        Test 2a: Chain 2 baseline
        GIVEN: No circuit breaker, 2-agent chain
        WHEN: run with multiple trials  
        THEN: CFR > 0 (cascades possible), some task failures
        """
        # GIVEN: No circuit breaker, 2-agent chain
        chain_length = 2
        condition = "NO_CB"
        
        # WHEN: run with multiple trials
        results = self.run_multiple_trials(chain_length, condition)
        
        # THEN: CFR > 0 (cascades possible), some task failures
        print(f"\n=== Test 2a: Chain 2 baseline ===")
        print(f"Average CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Completion rate: {results['completion_rate']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        
        # Assertions
        self.assertEqual(results['total_trips'], 0, "NO_CB should have 0 circuit trips")
        self.assertGreaterEqual(results['avg_cfr'], 0.0, "CFR should be non-negative")
        # With failure injection, we should see some failures
        self.assertLess(results['completion_rate'], 1.0, "Some tasks should fail with failure injection")
        
        return results
    
    def test_2b_chain_2_with_adaptive_cb(self):
        """
        Test 2b: Chain 2 with ADAPTIVE_CB
        GIVEN: 2-agent chain with ADAPTIVE_CB
        WHEN: run with multiple trials
        THEN: CFR reduced significantly, CB trips > 0, some protection evident
        """
        # GIVEN: 2-agent chain with ADAPTIVE_CB
        chain_length = 2
        condition = "ADAPTIVE_CB"
        
        # Get baseline for comparison
        baseline = self.run_multiple_trials(chain_length, "NO_CB")
        
        # WHEN: run with multiple trials  
        results = self.run_multiple_trials(chain_length, condition)
        
        # THEN: CFR reduced, CB trips > 0, protection evident
        print(f"\n=== Test 2b: Chain 2 with ADAPTIVE_CB ===")
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"ADAPTIVE_CB CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        print(f"CFR reduction: {(baseline['avg_cfr'] - results['avg_cfr'])*100:.1f} percentage points")
        
        # Assertions
        self.assertGreater(results['total_trips'], 0, "ADAPTIVE_CB should have some circuit trips")
        
        # If there are failures in baseline, CB should reduce CFR
        if baseline['avg_cfr'] > 0:
            cfr_reduction_pct = ((baseline['avg_cfr'] - results['avg_cfr']) / baseline['avg_cfr']) * 100
            print(f"CFR reduction percentage: {cfr_reduction_pct:.1f}%")
            # Expect meaningful reduction if circuit breaker is working
            self.assertGreaterEqual(cfr_reduction_pct, 10.0, 
                f"Circuit breaker should reduce CFR by at least 10%, got {cfr_reduction_pct:.1f}%")
        
        return results

    # ========================================
    # CHAIN 3 TESTS
    # ========================================
    
    def test_3a_chain_3_baseline(self):
        """
        Test 3a: Chain 3 baseline
        GIVEN: No circuit breaker, 3-agent chain
        WHEN: run with multiple trials
        THEN: CFR > 0 (cascades possible), higher CFR than chain 2
        """
        # GIVEN: No circuit breaker, 3-agent chain
        chain_length = 3
        condition = "NO_CB"
        
        # WHEN: run with multiple trials
        results = self.run_multiple_trials(chain_length, condition)
        
        # THEN: CFR > 0, potentially higher than chain 2
        print(f"\n=== Test 3a: Chain 3 baseline ===")
        print(f"Average CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Completion rate: {results['completion_rate']*100:.1f}%")
        
        self.assertEqual(results['total_trips'], 0, "NO_CB should have 0 circuit trips")
        self.assertGreaterEqual(results['avg_cfr'], 0.0, "CFR should be non-negative")
        
        return results
    
    def test_3b_chain_3_with_adaptive_cb(self):
        """
        Test 3b: Chain 3 with ADAPTIVE_CB
        GIVEN: 3-agent chain with ADAPTIVE_CB
        WHEN: run with multiple trials
        THEN: CFR reduced, CB trips > 0
        """
        # GIVEN: 3-agent chain with ADAPTIVE_CB
        chain_length = 3
        condition = "ADAPTIVE_CB"
        
        baseline = self.run_multiple_trials(chain_length, "NO_CB")
        
        # WHEN: run with multiple trials
        results = self.run_multiple_trials(chain_length, condition)
        
        # THEN: CFR reduced, CB trips > 0
        print(f"\n=== Test 3b: Chain 3 with ADAPTIVE_CB ===")
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"ADAPTIVE_CB CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        
        self.assertGreater(results['total_trips'], 0, "ADAPTIVE_CB should have circuit trips")
        
        return results

    # ========================================
    # CHAIN 4 TESTS
    # ========================================
    
    def test_4a_chain_4_baseline(self):
        """
        Test 4a: Chain 4 baseline
        GIVEN: No circuit breaker, 4-agent chain
        WHEN: run with multiple trials
        THEN: CFR > 0, higher failure rate due to longer chain
        """
        chain_length = 4
        condition = "NO_CB"
        
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 4a: Chain 4 baseline ===")
        print(f"Average CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Completion rate: {results['completion_rate']*100:.1f}%")
        
        self.assertEqual(results['total_trips'], 0)
        self.assertGreaterEqual(results['avg_cfr'], 0.0)
        
        return results
    
    def test_4b_chain_4_with_adaptive_cb(self):
        """
        Test 4b: Chain 4 with ADAPTIVE_CB
        GIVEN: 4-agent chain with ADAPTIVE_CB
        WHEN: run with multiple trials
        THEN: CFR reduced, CB trips > 0
        """
        chain_length = 4
        condition = "ADAPTIVE_CB"
        
        baseline = self.run_multiple_trials(chain_length, "NO_CB")
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 4b: Chain 4 with ADAPTIVE_CB ===")
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"ADAPTIVE_CB CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        
        self.assertGreater(results['total_trips'], 0)
        
        return results

    # ========================================
    # CHAIN 5 TESTS
    # ========================================
    
    def test_5a_chain_5_baseline(self):
        """
        Test 5a: Chain 5 baseline
        GIVEN: No circuit breaker, 5-agent chain
        WHEN: run with multiple trials
        THEN: CFR > 0, even higher failure rate
        """
        chain_length = 5
        condition = "NO_CB"
        
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 5a: Chain 5 baseline ===")
        print(f"Average CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Completion rate: {results['completion_rate']*100:.1f}%")
        
        self.assertEqual(results['total_trips'], 0)
        self.assertGreaterEqual(results['avg_cfr'], 0.0)
        
        return results
    
    def test_5b_chain_5_with_adaptive_cb(self):
        """
        Test 5b: Chain 5 with ADAPTIVE_CB
        GIVEN: 5-agent chain with ADAPTIVE_CB  
        WHEN: run with multiple trials
        THEN: CFR reduced, CB trips > 0
        """
        chain_length = 5
        condition = "ADAPTIVE_CB"
        
        baseline = self.run_multiple_trials(chain_length, "NO_CB")
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 5b: Chain 5 with ADAPTIVE_CB ===")
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"ADAPTIVE_CB CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        
        self.assertGreater(results['total_trips'], 0)
        
        return results

    # ========================================
    # CHAIN 6 TESTS - THE PROBLEMATIC CASE
    # ========================================
    
    def test_6a_chain_6_baseline(self):
        """
        Test 6a: Chain 6 baseline
        GIVEN: No circuit breaker, 6-agent chain
        WHEN: run with multiple trials
        THEN: CFR > 0, highest failure rate due to longest chain
        """
        chain_length = 6
        condition = "NO_CB"
        
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 6a: Chain 6 baseline ===")
        print(f"Average CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Completion rate: {results['completion_rate']*100:.1f}%")
        
        self.assertEqual(results['total_trips'], 0, "NO_CB should have 0 trips")
        self.assertGreaterEqual(results['avg_cfr'], 0.0, "CFR should be non-negative")
        
        return results
    
    def test_6b_chain_6_with_adaptive_cb(self):
        """
        Test 6b: Chain 6 with ADAPTIVE_CB - THE PROBLEMATIC CASE
        GIVEN: 6-agent chain with ADAPTIVE_CB
        WHEN: run with multiple trials
        THEN: Should have CB trips > 0 AND measurable CFR reduction
        
        BUG REPORT: Previously showed 0 CB trips but 39% reduction (impossible)
        """
        chain_length = 6
        condition = "ADAPTIVE_CB"
        
        baseline = self.run_multiple_trials(chain_length, "NO_CB")
        results = self.run_multiple_trials(chain_length, condition)
        
        print(f"\n=== Test 6b: Chain 6 with ADAPTIVE_CB (PROBLEMATIC CASE) ===")
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"ADAPTIVE_CB CFR: {results['avg_cfr']*100:.1f}%")
        print(f"Circuit trips: {results['total_trips']}")
        
        # CRITICAL ASSERTIONS - these should expose the bug
        if results['avg_cfr'] < baseline['avg_cfr']:
            # If there's a CFR reduction, there MUST be circuit trips
            self.assertGreater(results['total_trips'], 0, 
                f"CRITICAL BUG: CFR reduction without circuit trips! "
                f"Baseline: {baseline['avg_cfr']*100:.1f}%, "
                f"CB: {results['avg_cfr']*100:.1f}%, "
                f"Trips: {results['total_trips']}")
        
        # Circuit breaker should trip at least sometimes in a 6-agent chain
        self.assertGreater(results['total_trips'], 0, 
            "6-agent chain with ADAPTIVE_CB should have some circuit trips")
        
        return results

    # ========================================
    # INTEGRATION TESTS - ALL CONDITIONS
    # ========================================
    
    def test_all_conditions_chain_2(self):
        """Test all conditions on chain 2 for comparison."""
        print(f"\n{'='*50}")
        print("CHAIN 2 - ALL CONDITIONS COMPARISON")
        print(f"{'='*50}")
        
        results = {}
        for condition in CONDITIONS:
            results[condition] = self.run_multiple_trials(2, condition)
            
        self._print_comparison_table(results, 2)
        return results
    
    def test_all_conditions_chain_6(self):
        """Test all conditions on chain 6 - the problematic case."""
        print(f"\n{'='*50}")
        print("CHAIN 6 - ALL CONDITIONS COMPARISON (PROBLEMATIC)")
        print(f"{'='*50}")
        
        results = {}
        for condition in CONDITIONS:
            results[condition] = self.run_multiple_trials(6, condition)
            
        self._print_comparison_table(results, 6)
        return results
    
    def _print_comparison_table(self, results: dict, chain_length: int):
        """Print a comparison table for all conditions."""
        print(f"\n| CB Type      | CFR (%)  | Complete (%) | Avg Trips | Total Trips |")
        print(f"|--------------|----------|--------------|-----------|-------------|")
        
        for condition, result in results.items():
            cfr_pct = result['avg_cfr'] * 100
            comp_pct = result['completion_rate'] * 100
            avg_trips = result['avg_trips']
            total_trips = result['total_trips']
            
            print(f"| {condition:<12} | {cfr_pct:6.1f}%  | {comp_pct:10.1f}% | {avg_trips:7.1f}   | {total_trips:9d}   |")

    # ========================================
    # BUG REPRODUCTION TESTS
    # ========================================
    
    def test_reproduce_chain_2_issue(self):
        """
        Reproduce the specific Chain 2 issue:
        5,547 CB trips but only 1% reduction (should be ~80%)
        """
        print(f"\n{'='*60}")
        print("REPRODUCING CHAIN 2 ISSUE: Many trips, low reduction")
        print(f"{'='*60}")
        
        # Run with higher number of trials to match consultant report
        baseline = self.run_multiple_trials(2, "NO_CB", runs=100)
        cb_result = self.run_multiple_trials(2, "ADAPTIVE_CB", runs=100)
        
        cfr_reduction_pct = ((baseline['avg_cfr'] - cb_result['avg_cfr']) / baseline['avg_cfr'] * 100 
                            if baseline['avg_cfr'] > 0 else 0)
        
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")  
        print(f"CB CFR: {cb_result['avg_cfr']*100:.1f}%")
        print(f"Total CB trips: {cb_result['total_trips']}")
        print(f"CFR reduction: {cfr_reduction_pct:.1f}%")
        
        # The issue: high trips but low effectiveness
        if cb_result['total_trips'] > 1000 and cfr_reduction_pct < 20:
            print(f"🐛 BUG REPRODUCED: {cb_result['total_trips']} trips but only {cfr_reduction_pct:.1f}% reduction")
    
    def test_reproduce_chain_6_issue(self):
        """
        Reproduce the specific Chain 6 issue:
        0 CB trips but 39% "reduction" (impossible)
        """
        print(f"\n{'='*60}")
        print("REPRODUCING CHAIN 6 ISSUE: 0 trips but phantom reduction")
        print(f"{'='*60}")
        
        baseline = self.run_multiple_trials(6, "NO_CB", runs=100)
        cb_result = self.run_multiple_trials(6, "ADAPTIVE_CB", runs=100)
        
        cfr_reduction_pct = ((baseline['avg_cfr'] - cb_result['avg_cfr']) / baseline['avg_cfr'] * 100 
                            if baseline['avg_cfr'] > 0 else 0)
        
        print(f"Baseline CFR: {baseline['avg_cfr']*100:.1f}%")
        print(f"CB CFR: {cb_result['avg_cfr']*100:.1f}%")  
        print(f"Total CB trips: {cb_result['total_trips']}")
        print(f"CFR reduction: {cfr_reduction_pct:.1f}%")
        
        # The issue: reduction without trips (impossible)
        if cb_result['total_trips'] == 0 and cfr_reduction_pct > 10:
            print(f"🐛 BUG REPRODUCED: {cb_result['total_trips']} trips but {cfr_reduction_pct:.1f}% reduction (IMPOSSIBLE)")


def main():
    """Run all Given-When-Then tests."""
    # Run tests with verbose output
    unittest.main(verbosity=2, buffer=False, argv=[''])


if __name__ == "__main__":
    main()