""" 5-Agent Chain Circuit Breaker Experiment ========================================= Chain length: 5 agents (A → B → C → D → E) CB types: NO_CB, SIMPLE_CB, AI_CB, ADAPTIVE_CB Runs: 50 per condition Output: CFR results table """
import json
import random
import time
from dataclasses import dataclass
from typing import List, Dict, Optional, Tuple
from collections import defaultdict
from circuit_breaker import (
    AIAdaptiveCircuitBreaker,
    SimpleCircuitBreaker,
    NoProtection,
    CircuitConfig,
    Response,
    CircuitBreakerOpenError
)

# Configuration
CHAIN_LENGTH = 5
RUNS_PER_CONDITION = 50
CONDITIONS = ["NO_CB", "SIMPLE_CB", "AI_CB", "ADAPTIVE_CB"]
FAILURE_INJECTION_RATE = 0.35  # 35% chance of failure per agent call
SEED = 42

@dataclass
class FailureEvent:
    """Track failure events for CFR calculation."""
    agent_id: str
    failure_type: str
    turn_number: int
    task_id: str

class CFRTracker:
    """Tracks cascading failure rate across agent chain."""
    def __init__(self, propagation_window_turns: int = 2):
        self.propagation_window = propagation_window_turns
        self.failures: List[FailureEvent] = []
        self.initial_failures = 0
        self.cascaded_failures = 0

    def record_failure(self, event: FailureEvent) -> None:
        """Record a failure event."""
        self.failures.append(event)

    def calculate_cfr(self) -> Dict[str, float]:
        """
        Calculate CFR: proportion of failures that cascaded from one agent to another.
        CFR = cascaded_failures / total_failures (if total > 0)
        """
        if len(self.failures) == 0:
            return {"cfr_rate": 0.0, "initial": 0, "cascaded": 0, "total_failures": 0}

        self.initial_failures = 0
        self.cascaded_failures = 0

        for f in self.failures:
            if "cascaded" in f.failure_type:
                self.cascaded_failures += 1
            else:
                self.initial_failures += 1

        total = self.initial_failures + self.cascaded_failures
        cfr_rate = self.cascaded_failures / total if total > 0 else 0.0

        return {
            "cfr_rate": cfr_rate,
            "initial": self.initial_failures,
            "cascaded": self.cascaded_failures,
            "total_failures": total
        }

class StubLLM:
    """Stubbed LLM for deterministic testing."""
    def __init__(self, seed: int, failure_rate: float = 0.35):
        self.seed = seed
        self.failure_rate = failure_rate

    def generate_response(self, agent_id: str, run_id: str, turn_number: int) -> Response:
        """Generate a stubbed response with controlled failure injection."""
        response_seed = hash(f"{self.seed}_{run_id}_{agent_id}_{turn_number}")
        rng = random.Random(response_seed)

        if rng.random() < self.failure_rate:
            failure_type = rng.choice(["low_confidence", "high_tokens", "inconsistent"])
            if failure_type == "low_confidence":
                return Response(
                    content=f"Low confidence response from {agent_id}",
                    confidence=rng.uniform(0.1, 0.4),
                    token_usage=rng.randint(1000, 3000),
                    reasoning="Uncertain about this response"
                )
            elif failure_type == "high_tokens":
                return Response(
                    content=f"Verbose response from {agent_id}",
                    confidence=rng.uniform(0.6, 0.8),
                    token_usage=rng.randint(6500, 8000),
                    reasoning="Complete analysis"
                )
            else:
                return Response(
                    content=f"Here is the definitive answer from {agent_id}",
                    confidence=rng.uniform(0.5, 0.7),
                    token_usage=rng.randint(2000, 4000),
                    reasoning="I don't know the answer and have low confidence"
                )

        return Response(
            content=f"Successful response from {agent_id}",
            confidence=rng.uniform(0.7, 0.95),
            token_usage=rng.randint(500, 2000),
            reasoning=f"Processed request successfully in {agent_id}"
        )

class FiveAgentChainSystem:
    """5-agent chain: A → B → C → D → E"""
    def __init__(self, condition: str, run_id: str, seed: int = 42):
        self.condition = condition
        self.run_id = run_id
        self.seed = seed
        self.turn_number = 0
        self.cfr_tracker = CFRTracker()
        self.stub_llm = StubLLM(seed, failure_rate=FAILURE_INJECTION_RATE)
        self.circuit_breakers = {
            f"agent_{chr(65+i)}": self._create_circuit_breaker()
            for i in range(CHAIN_LENGTH)
        }
        self.metrics = {
            "agent_failures": {f"agent_{chr(65+i)}": 0 for i in range(CHAIN_LENGTH)},
            "circuit_trips": 0,
            "task_completed": False,
            "chain_reached": 0,
        }

    def _create_circuit_breaker(self):
        if self.condition == "NO_CB":
            return NoProtection()
        elif self.condition == "SIMPLE_CB":
            return SimpleCircuitBreaker(failure_threshold=2, timeout_seconds=15.0)
        elif self.condition == "AI_CB":
            config = CircuitConfig(
                confidence_threshold=0.5, context_threshold=6000, predictability_min=0.3,
                failure_threshold=2, timeout_seconds=15.0
            )
            return AIAdaptiveCircuitBreaker(config)
        elif self.condition == "ADAPTIVE_CB":
            config = CircuitConfig(
                confidence_threshold=0.6, context_threshold=5000, predictability_min=0.35,
                failure_threshold=2, timeout_seconds=10.0
            )
            return AIAdaptiveCircuitBreaker(config)
        else:
            return NoProtection()

    def _is_quality_failure(self, response: Response) -> bool:
        if response.confidence < 0.5:
            return True
        if response.token_usage > 6000:
            return True
        if response.reasoning:
            rl = response.reasoning.lower()
            cl = response.content.lower()
            if (("don't know" in rl or "uncertain" in rl or "low confidence" in rl) and 
                "successful" in cl):
                return True
        return False

    def _call_agent(self, agent_id: str, input_data: str, prev_had_failure: bool = False):
        cb = self.circuit_breakers[agent_id]
        self.turn_number += 1
        try:
            def agent_call():
                return self.stub_llm.generate_response(agent_id, self.run_id, self.turn_number)
            response = cb.call(agent_call)
            quality_failure = self._is_quality_failure(response)
            if quality_failure:
                ftype = "cascaded" if prev_had_failure else "initial"
                self.cfr_tracker.record_failure(FailureEvent(
                    agent_id=agent_id, failure_type=ftype,
                    turn_number=self.turn_number, task_id=self.run_id))
                self.metrics["agent_failures"][agent_id] += 1
            return response, True, quality_failure
        except CircuitBreakerOpenError as e:
            self.metrics["circuit_trips"] += 1
            ftype = "cascaded_blocked" if prev_had_failure else "blocked"
            self.cfr_tracker.record_failure(FailureEvent(
                agent_id=agent_id, failure_type=ftype,
                turn_number=self.turn_number, task_id=self.run_id))
            return None, False, True
        except Exception as e:
            self.metrics["agent_failures"][agent_id] += 1
            ftype = "cascaded_exception" if prev_had_failure else "exception"
